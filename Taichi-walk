];

const soundLabels = { none:'', rain:'Rain', ocean:'Ocean', drone:'Drone' };

let mode='guided', ambientChoice='none', current=0, remaining=0;
let stepTimer=null, countdownTimer=null, paused=false, countdownVal=8;
let ambCtx=null, ambMaster=null, ambSources=[];
let previewCtx=null, previewMaster=null, previewSources=[], previewTimer=null;

function selectMode(m) {
  mode=m;
  document.getElementById('btn-guided').classList.toggle('selected',m==='guided');
  document.getElementById('btn-flow').classList.toggle('selected',m==='flow');
}

// ── HOME SCREEN: tap to preview for 3s, tap again to confirm selection ───────
function selectAmbient(choice) {
  stopPreview();
  // If already selected, do nothing extra
  if (ambientChoice === choice) return;
  ambientChoice = choice;
  refreshAllSoundUIs();
  if (choice === 'none') return;
  // Play a 3-second preview
  startPreview(choice);
}

function startPreview(choice) {
  stopPreview();
  document.getElementById('amb-'+choice).classList.add('previewing');
  try {
    previewCtx = new (window.AudioContext||window.webkitAudioContext)();
    previewMaster = previewCtx.createGain();
    previewMaster.gain.setValueAtTime(0, previewCtx.currentTime);
    previewMaster.connect(previewCtx.destination);
    const doPreview = () => {
      if (!previewCtx) return;
      previewMaster.gain.setValueAtTime(0, previewCtx.currentTime);
      previewMaster.gain.linearRampToValueAtTime(0.75, previewCtx.currentTime+0.6);
      if (choice==='rain')  buildRain(previewCtx, previewMaster, previewSources);
      if (choice==='ocean') buildOcean(previewCtx, previewMaster, previewSources);
      if (choice==='drone') buildDrone(previewCtx, previewMaster, previewSources);
    };
    if (previewCtx.state === 'suspended') {
      previewCtx.resume().then(doPreview).catch(doPreview);
    } else {
      doPreview();
    }
  } catch(e){}
  previewTimer = setTimeout(stopPreview, 3000);
}

function stopPreview() {
  clearTimeout(previewTimer);
  ['none','rain','ocean','drone'].forEach(id=>{
    const b=document.getElementById('amb-'+id);
    if(b) b.classList.remove('previewing');
  });
  if (!previewCtx) return;
  try {
    previewMaster.gain.setValueAtTime(previewMaster.gain.value, previewCtx.currentTime);
    previewMaster.gain.linearRampToValueAtTime(0, previewCtx.currentTime+0.5);
    setTimeout(()=>{
      previewSources.forEach(s=>{try{s.stop();}catch(e){}});
      previewSources=[];
      try{previewCtx.close();}catch(e){}
      previewCtx=null; previewMaster=null;
    },700);
  } catch(e){}
}

// ── IN-PRACTICE: hot-swap ambient sound immediately ───────────────────────────
function switchAmbient(choice) {
  stopPreview();
  ambientChoice = choice;
  refreshAllSoundUIs();
  // If practice is running, swap audio live
  if (ambCtx) {
    stopAmbient();
    if (choice !== 'none') startAmbient();
  }
}

// Keep all three sound UIs in sync
function refreshAllSoundUIs() {
  // Home screen buttons
  ['none','rain','ocean','drone'].forEach(id=>{
    const b=document.getElementById('amb-'+id);
    if(b) b.classList.toggle('selected', id===ambientChoice);
  });
  // Prep page switcher
  ['none','rain','ocean','drone'].forEach(id=>{
    const b=document.getElementById('psw-'+id);
    if(b) b.classList.toggle('selected', id===ambientChoice);
  });
  // Practice page switcher
  ['none','rain','ocean','drone'].forEach(id=>{
    const b=document.getElementById('xsw-'+id);
    if(b) b.classList.toggle('selected', id===ambientChoice);
  });
  // Sound badge on practice screen
  const sb=document.getElementById('p-sound-badge');
  if(sb){
    if(ambientChoice!=='none'){sb.classList.remove('hidden');sb.textContent=soundLabels[ambientChoice];}
    else{sb.classList.add('hidden');}
  }
  // Ambient pill on prep screen
  const pill=document.getElementById('ambient-pill');
  if(pill){
    if(ambientChoice!=='none'){pill.classList.remove('hidden');pill.textContent=soundLabels[ambientChoice]+' playing';}
    else{pill.classList.add('hidden');}
  }
}

// ── AMBIENT ──────────────────────────────────────────────────────────────────
function startAmbient() {
  stopAmbient();
  if (ambientChoice==='none') return;
  try {
    ambCtx = new (window.AudioContext||window.webkitAudioContext)();
    ambMaster = ambCtx.createGain();
    ambMaster.gain.setValueAtTime(0, ambCtx.currentTime);
    ambMaster.connect(ambCtx.destination);
    const choice = ambientChoice;
    const doStart = () => {
      if (!ambCtx) return;
      ambMaster.gain.setValueAtTime(0, ambCtx.currentTime);
      ambMaster.gain.linearRampToValueAtTime(0.85, ambCtx.currentTime+4);
      if (choice==='rain')  buildRain(ambCtx,ambMaster,ambSources);
      if (choice==='ocean') buildOcean(ambCtx,ambMaster,ambSources);
      if (choice==='drone') buildDrone(ambCtx,ambMaster,ambSources);
    };
    if (ambCtx.state === 'suspended') {
      ambCtx.resume().then(doStart).catch(doStart);
    } else {
      doStart();
    }
  } catch(e){}
}

function stopAmbient() {
  if (!ambCtx) return;
  try {
    ambMaster.gain.setValueAtTime(ambMaster.gain.value,ambCtx.currentTime);
    ambMaster.gain.linearRampToValueAtTime(0,ambCtx.currentTime+2.5);
    setTimeout(()=>{
      ambSources.forEach(s=>{try{s.stop();}catch(e){}});
      ambSources=[];
      try{ambCtx.close();}catch(e){}
      ambCtx=null; ambMaster=null;
    },3000);
  } catch(e){}
}

function buildRain(ctx,dest,sources) {
  const rate=ctx.sampleRate, buf=ctx.createBuffer(1,rate*5,rate), d=buf.getChannelData(0);
  let b0=0,b1=0,b2=0,b3=0,b4=0,b5=0,b6=0;
  for(let i=0;i<d.length;i++){
    const w=Math.random()*2-1;
    b0=0.99886*b0+w*0.0555179; b1=0.99332*b1+w*0.0750759;
    b2=0.96900*b2+w*0.1538520; b3=0.86650*b3+w*0.3104856;
    b4=0.55000*b4+w*0.5329522; b5=-0.7616*b5-w*0.0168980;
    d[i]=(b0+b1+b2+b3+b4+b5+b6+w*0.5362)*0.11; b6=w*0.115926;
  }
  const src=ctx.createBufferSource(); src.buffer=buf; src.loop=true;
  const hp=ctx.createBiquadFilter(); hp.type='highpass'; hp.frequency.value=400;
  const bp=ctx.createBiquadFilter(); bp.type='bandpass'; bp.frequency.value=1600; bp.Q.value=0.5;
  const g=ctx.createGain(); g.gain.value=0.7;
  src.connect(hp); hp.connect(bp); bp.connect(g); g.connect(dest);
  src.start(); sources.push(src);
}

function buildOcean(ctx,dest,sources) {
  const rate=ctx.sampleRate, buf=ctx.createBuffer(1,rate*6,rate), d=buf.getChannelData(0);
  let last=0;
  for(let i=0;i<d.length;i++){const w=Math.random()*2-1;last=(last+0.02*w)/1.02;d[i]=last*3.5;}
  const src=ctx.createBufferSource(); src.buffer=buf; src.loop=true;
  const lp=ctx.createBiquadFilter(); lp.type='lowpass'; lp.frequency.value=650;
  const ng=ctx.createGain(); ng.gain.value=0.5;
  const lfo=ctx.createOscillator(), lfoG=ctx.createGain();
  lfo.frequency.value=0.065; lfoG.gain.value=0.28;
  lfo.connect(lfoG); lfoG.connect(ng.gain);
  src.connect(lp); lp.connect(ng); ng.connect(dest);
  src.start(); lfo.start(); sources.push(src,lfo);
}

function buildDrone(ctx,dest,sources) {
  [[110,0.15,0.12,0.25],[165,0.10,0.17,0.20],[220,0.08,0.09,0.30],[275,0.05,0.21,0.18],[330,0.04,0.14,0.15]].forEach(([f,gv,vr,vd])=>{
    const osc=ctx.createOscillator(), g=ctx.createGain();
    const vLFO=ctx.createOscillator(), vG=ctx.createGain();
    osc.type='sine'; osc.frequency.value=f;
    vLFO.frequency.value=vr; vG.gain.value=vd;
    vLFO.connect(vG); vG.connect(osc.frequency);
    g.gain.value=gv; osc.connect(g); g.connect(dest);
    osc.start(); vLFO.start(); sources.push(osc,vLFO);
  });
}

// ── BELL ─────────────────────────────────────────────────────────────────────
function playBell() {
  try {
    const ctx = new (window.AudioContext||window.webkitAudioContext)();
    const play = () => {
      const now = ctx.currentTime;
      [[528,0.28,2.8],[792,0.12,2.0],[1056,0.05,1.4]].forEach(([f,vol,dur])=>{
        const osc=ctx.createOscillator(), g=ctx.createGain();
        osc.type='sine'; osc.frequency.value=f;
        g.gain.setValueAtTime(0,now); g.gain.linearRampToValueAtTime(vol,now+0.01);
        g.gain.exponentialRampToValueAtTime(0.001,now+dur);
        osc.connect(g); g.connect(ctx.destination); osc.start(now); osc.stop(now+dur+0.1);
      });
      setTimeout(()=>ctx.close(),3500);
    };
    if (ctx.state === 'suspended') {
      ctx.resume().then(play).catch(play);
    } else {
      play();
    }
  } catch(e){}
}

// ── FLOW ─────────────────────────────────────────────────────────────────────
function beginPractice() {
  stopPreview();
  document.getElementById('home-view').classList.add('hidden');
  startAmbient();
  showPrep(0);
}

function showPrep(i) {
  clearInterval(stepTimer); clearInterval(countdownTimer);
  if (i>=steps.length){showComplete();return;}
  current=i;
  const s=steps[i];
  document.getElementById('prep-label').textContent=(i===0?'First up':'Next up')+' \u2022 Step '+(i+1)+' of '+steps.length;
  document.getElementById('prep-icon').innerHTML=s.icon;
  document.getElementById('prep-name').textContent=s.name;
  document.getElementById('prep-duration').textContent=s.duration+' seconds';
  document.getElementById('prep-desc').textContent=s.desc;
  document.getElementById('prep-breath').textContent=s.breath;
  refreshAllSoundUIs();
  document.getElementById('practice-view').classList.remove('active');
  document.getElementById('complete-view').classList.remove('active');
  document.getElementById('prep-view').classList.add('active');
  if(mode==='flow'){
    document.getElementById('auto-countdown').classList.remove('hidden');
    document.getElementById('prep-start-btn').classList.add('hidden');
    countdownVal=8; document.getElementById('countdown-num').textContent=countdownVal;
    countdownTimer=setInterval(()=>{
      countdownVal--; document.getElementById('countdown-num').textContent=countdownVal;
      if(countdownVal<=0){clearInterval(countdownTimer);startStep();}
    },1000);
  } else {
    document.getElementById('auto-countdown').classList.add('hidden');
    document.getElementById('prep-start-btn').classList.remove('hidden');
  }
}

function startStep() {
  clearInterval(countdownTimer);
  const s=steps[current]; remaining=s.duration; paused=false;
  document.getElementById('p-counter').textContent='Step '+(current+1)+' of '+steps.length;
  document.getElementById('p-mode-badge').textContent=mode==='guided'?'Guided':'Flow';
  document.getElementById('p-icon').innerHTML=s.icon;
  document.getElementById('p-name').textContent=s.name;
  document.getElementById('p-desc').textContent=s.desc;
  document.getElementById('p-breath').textContent=s.breath;
  document.getElementById('pause-btn').textContent='Pause';
  refreshAllSoundUIs();
  updateDisplay();
  document.getElementById('prep-view').classList.remove('active');
  document.getElementById('practice-view').classList.add('active');
  clearInterval(stepTimer);
  stepTimer=setInterval(tick,1000);
}

function tick() {
  if(paused)return;
  remaining--;
  updateDisplay();
  if(remaining<=0){clearInterval(stepTimer);playBell();setTimeout(()=>showPrep(current+1),1400);}
}

function updateDisplay() {
  document.getElementById('p-timer').textContent=remaining;
  document.getElementById('p-fill').style.width=(remaining/steps[current].duration*100)+'%';
}

function togglePause(){paused=!paused;document.getElementById('pause-btn').textContent=paused?'Resume':'Pause';}
function skipStep(){clearInterval(stepTimer);playBell();setTimeout(()=>showPrep(current+1),600);}
function prevStep(){clearInterval(stepTimer);clearInterval(countdownTimer);showPrep(Math.max(0,current-1));}

function showComplete() {
  clearInterval(stepTimer); clearInterval(countdownTimer);
  playBell(); stopAmbient();
  setTimeout(()=>{
    document.getElementById('prep-view').classList.remove('active');
    document.getElementById('practice-view').classList.remove('active');
    document.getElementById('complete-view').classList.add('active');
  },900);
}

function endPractice() {
  clearInterval(stepTimer); clearInterval(countdownTimer);
  stopAmbient();
  ['prep-view','practice-view','complete-view'].forEach(id=>document.getElementById(id).classList.remove('active'));
  document.getElementById('home-view').classList.remove('hidden');
}
</script>

