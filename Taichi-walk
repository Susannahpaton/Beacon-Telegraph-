  <button class="mode-btn selected" id="btn-guided" onclick="selectMode('guided')">
    <strong>&#9711; Guided</strong>Each step begins when you are ready. Ideal for beginners.
  </button>
  <button class="mode-btn" id="btn-flow" onclick="selectMode('flow')">
    <strong>&#9654; Flow</strong>Steps advance automatically. For experienced practitioners.
  </button>
